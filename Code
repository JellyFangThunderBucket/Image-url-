          <div>
            <strong>Image Max URL iPhone</strong>
            <span id="${PATCH_ID}-count">No scan yet</span>
          </div>
          <div class="${PATCH_ID}-window-actions">
            <button type="button" data-center-action="collapse" aria-label="Collapse">–</button>
            <button type="button" data-center-action="close" aria-label="Close">×</button>
          </div>
        </header>
        <div class="${PATCH_ID}-collapsible">
          <section id="${PATCH_ID}-status" class="${PATCH_ID}-status"></section>
          <label class="${PATCH_ID}-advanced"><input type="checkbox" id="${PATCH_ID}-advanced-toggle"> Advanced Mode</label>
          <div class="${PATCH_ID}-filters">
            <label>Type <select id="${PATCH_ID}-filter-type"><option value="all">All</option><option value="common">JPG/PNG/WebP only</option><option value="jpg">JPG only</option><option value="png">PNG only</option><option value="webp">WebP only</option></select></label>
            <label>Sort <select id="${PATCH_ID}-sort"><option value="size">Estimated size</option><option value="filename">Filename length</option><option value="confidence">Source confidence</option></select></label>
            <label><input type="checkbox" id="${PATCH_ID}-hide-dupes" checked> Hide duplicates</label>
            <label><input type="checkbox" id="${PATCH_ID}-large-only"> Large only</label>
            <label><input type="checkbox" id="${PATCH_ID}-verified-only"> Verified only</label>
