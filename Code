  function ensureFullscreenPreview() {
    if (fullscreenPreview) return;
    fullscreenPreview = document.createElement('div');
    fullscreenPreview.id = `${PATCH_ID}-preview`;
    fullscreenPreview.hidden = true;
    fullscreenPreview.innerHTML = `
      <div class="${PATCH_ID}-preview-card">
