    controlCenter.querySelector(`#${PATCH_ID}-advanced-toggle`).addEventListener('change', toggleAdvancedMode);
    controlCenter.querySelector(`#${PATCH_ID}-filter-type`).addEventListener('change', (event) => { state.filterType = event.target.value; state.visibleCount = 40; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-sort`).addEventListener('change', (event) => { state.sortBy = event.target.value; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-hide-dupes`).addEventListener('change', (event) => { state.hideDuplicates = event.target.checked; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-large-only`).addEventListener('change', (event) => { state.largeOnly = event.target.checked; state.visibleCount = 40; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-verified-only`).addEventListener('change', (event) => { state.verifiedOnly = event.target.checked; state.visibleCount = 40; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-likely-only`).addEventListener('change', (event) => { state.likelyOnly = event.target.checked; state.visibleCount = 40; refreshDisplayCandidates(); });
    controlCenter.querySelector(`#${PATCH_ID}-include-page-links`).addEventListener('change', (event) => { state.includePageLinks = event.target.checked; state.visibleCount = 40; refreshDisplayCandidates(); });
    document.documentElement.appendChild(controlCenter);
  }

  function onPanelScroll() {
    const panel = controlCenter?.querySelector(`.${PATCH_ID}-panel`);
    if (!panel || panel.scrollTop + panel.clientHeight < panel.scrollHeight - 240) return;
    if (state.visibleCount < pageCandidates.length) {
      state.visibleCount += 40;
      renderControlCenterList(true);
    }
  }

  function onControlCenterClick(event) {
    const action = event.target?.getAttribute?.('data-center-action');
    const rowButtonUrl = event.target?.getAttribute?.('data-url');
    const rowAction = event.target?.getAttribute?.('data-row-action');

    if (rowButtonUrl && rowAction) {
      if (rowAction === 'open') return openNormally(rowButtonUrl);
      if (rowAction === 'copy') return copyNormally(rowButtonUrl);
      if (rowAction === 'save') return saveOrOpen(rowButtonUrl);
      if (rowAction === 'preview') return openFullscreenPreview(rowButtonUrl);
    }

    if (!action) return;
    if (action === 'scan') return scanPage(true);
    if (action === 'selectAll') return selectAllVisible();
    if (action === 'openSelected') return openSelected();
    if (action === 'copySelected') return copySelectedUrls();
    if (action === 'exportText') return exportUrlsAsText();
    if (action === 'copyAll') return copyAllUrls();
    if (action === 'showMore') { state.visibleCount += 40; return renderControlCenterList(true); }
    if (action === 'collapse') return togglePanelCollapse();
    if (action === 'close') return closeControlCenter();
  }

  function renderControlCenterList(forceOpen = false) {
    if (!controlCenter) return;
    const count = controlCenter.querySelector(`#${PATCH_ID}-count`);
    const status = controlCenter.querySelector(`#${PATCH_ID}-status`);
    const list = controlCenter.querySelector(`#${PATCH_ID}-list`);
    const advancedToggle = controlCenter.querySelector(`#${PATCH_ID}-advanced-toggle`);
    pageCandidates = getDisplayCandidates();
    const candidates = pageCandidates.slice(0, state.visibleCount);

    advancedToggle.checked = state.advancedMode;
    count.textContent = `${pageCandidates.length} shown · ${state.uniqueFound} unique`;
    status.innerHTML = `
      <span>Total images found: <strong>${state.totalFound}</strong></span>
      <span>Unique images found: <strong>${state.uniqueFound}</strong></span>
      <span>Displayed after filters: <strong>${pageCandidates.length}</strong></span>
      <span>Selected: <strong>${state.selectedUrls.size}</strong></span>
      <span>Current mode: <strong>${state.advancedMode ? ADVANCED_MODE : SAFE_MODE}</strong></span>
      <span>APIs: XHR ${api.xhr ? 'yes' : 'no'} · Download ${api.download ? 'yes' : 'no'} · Clipboard ${api.setClipboard ? 'yes' : 'no'}</span>
      ${state.isChecking ? '<span>Checking HD guesses…</span>' : ''}
    `;
    list.innerHTML = candidates.length ? candidates.map(renderCandidateRow).join('') : '<li>No images found yet. Tap Scan page.</li>';
    list.hidden = !forceOpen && !candidates.length;
  }

  function renderCandidateRow(candidate, index) {
    const checked = state.selectedUrls.has(candidate.url) ? 'checked' : '';
    const dimensions = dimensionLabel(candidate);
    const confidenceLabel = CONFIDENCE_LABELS[candidate.confidence || CONFIDENCE.PAGE_LINK] || 'POSSIBLE_IMAGE';
    const badges = `${candidate.kind === 'guess' ? '<b class="imu-iphone-compat-badge">HD guessed</b>' : ''}${candidate.checked && candidate.ok ? '<b class="imu-iphone-compat-badge imu-iphone-compat-verified">Verified</b>' : ''}<b class="imu-iphone-compat-badge imu-iphone-compat-confidence">${confidenceLabel}</b>`;
    return `
      <li class="${PATCH_ID}-result">
        <label class="${PATCH_ID}-pick"><input type="checkbox" data-select-url="${escapeAttribute(candidate.url)}" ${checked}></label>
        <button type="button" class="${PATCH_ID}-thumb" data-row-action="preview" data-url="${escapeAttribute(candidate.url)}" aria-label="Open preview"><img src="${escapeAttribute(candidate.thumb || candidate.url)}" alt="" loading="lazy" referrerpolicy="no-referrer"></button>
        <div class="${PATCH_ID}-meta">
          <strong>${index + 1}. ${escapeHtml(shortUrl(candidate.url))} ${badges}</strong>
          <span>Source: ${escapeHtml(candidate.source || 'page URL')} · Type: ${escapeHtml(candidate.mediaType || 'image')} · ${dimensions}</span>
          <small>${escapeHtml(candidate.url)}</small>
          <details class="${PATCH_ID}-debug"><summary>Debug score ${Math.round(effectiveScore(candidate))}</summary><small>Matched: ${escapeHtml((candidate.rules || []).join(', ') || 'none')}<br>Reason: ${escapeHtml(candidate.debugReason || 'No debug reason')}<br>Advanced verified: ${candidate.checked && candidate.ok ? 'yes' : 'no'}${candidate.contentLength ? `<br>HEAD content-length: ${candidate.contentLength}` : ''}</small></details>
          <div class="${PATCH_ID}-row-actions">
            <button type="button" data-row-action="preview" data-url="${escapeAttribute(candidate.url)}">Fullscreen</button>
            <button type="button" data-row-action="open" data-url="${escapeAttribute(candidate.url)}">Open</button>
            <button type="button" data-row-action="copy" data-url="${escapeAttribute(candidate.url)}">Copy</button>
            <button type="button" data-row-action="save" data-url="${escapeAttribute(candidate.url)}">Save/Open</button>
          </div>
        </div>
      </li>
    `;
  }

  function dimensionLabel(candidate) {
    if (candidate.width && candidate.height) return `${candidate.width}×${candidate.height}`;
