      if (event.target === fullscreenPreview || event.target?.hasAttribute?.('data-preview-close')) closeFullscreenPreview();
    });
    fullscreenPreview.addEventListener('touchstart', (event) => { previewTouchStart = event.touches?.[0]?.clientY || null; }, { passive: true });
    fullscreenPreview.addEventListener('touchend', (event) => {
      if (previewTouchStart == null) return;
      const endY = event.changedTouches?.[0]?.clientY || previewTouchStart;
      if (endY - previewTouchStart > 80) closeFullscreenPreview();
      previewTouchStart = null;
    }, { passive: true });
    document.documentElement.appendChild(fullscreenPreview);
  }

